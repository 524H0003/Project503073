{
    "compilerOptions": {
        "target": "ESNext",
        "module": "esnext",
        "lib": [
            "dom",
            "dom.iterable",
            "esnext"
        ],
        "noEmit": true,
        "allowJs": false,
        "esModuleInterop": true,
        "isolatedModules": true,
        "moduleResolution": "bundler",
        "types": [
            "vite/client"
        ],
        "jsx": "react-jsx",
        "strict": true,
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "resources/js/*"
            ],
            "ziggy-js": [
                "./vendor/tightenco/ziggy"
            ]
        }
    }
}